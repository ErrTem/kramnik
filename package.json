{
  "name": "kramnik-shop",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.4"
  }
}
