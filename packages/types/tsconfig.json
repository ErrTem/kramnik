{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node10",
    "lib": ["ES2023"]
  },
  "include": ["src"]
}
