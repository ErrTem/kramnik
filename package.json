{
  "name": "kramnik-shop",
  "private": true,
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @kramnik/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @kramnik/api exec prisma db seed",
    "db:studio": "pnpm --filter @kramnik/api exec prisma studio",
    "db:reset": "pnpm --filter @kramnik/api exec prisma migrate reset",
    "db:generate": "pnpm --filter @kramnik/api exec prisma generate",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}
